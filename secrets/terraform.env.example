# Template — copy to terraform.env, fill in real values, then `sops -e -i terraform.env`
# Encrypted file is committed; plaintext copy is gitignored.

# Hetzner Cloud — https://console.hetzner.cloud → Project → Security → API Tokens
HCLOUD_TOKEN=

# AWS — for Route53 management + S3 Terraform state backend
# Created during bootstrap (stacks/tfstate-backend) as a scoped IAM user
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Route53 — hosted zone ID for the apex domain
ROUTE53_ZONE_ID=
