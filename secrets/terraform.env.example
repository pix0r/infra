# Template — copy to terraform.env, fill in real values, then `sops -e -i terraform.env`
# Encrypted file is committed; plaintext copy is gitignored.
#
# Two flavors of env var live here:
#   - AWS_*              standard AWS SDK names; the AWS Terraform provider picks them up
#   - TF_VAR_*           Terraform's auto-binding convention; each maps to a `variable` block
#
# Result: `sops exec-env secrets/terraform.env tofu apply` Just Works™ — no -var= clutter.

# ──── AWS ───────────────────────────────────────────────────────────────────
# Scoped IAM user (matz-infra-tofu) created by bootstrap.
# Capture from `tofu output -raw access_key_id` after first bootstrap run.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ──── Terraform variables ───────────────────────────────────────────────────
# Hetzner Cloud — https://console.hetzner.cloud → Project → Security → API Tokens
TF_VAR_hcloud_token=

# Route53 — hosted zone ID for matz.io (from `aws route53 list-hosted-zones`)
TF_VAR_route53_zone_id=

# Domain config (not secret, but lives here for one-stop env loading)
TF_VAR_domain=matz.io
