.terraform/
*.tfstate
*.tfstate.backup
.terraform.lock.hcl
terraform.tfvars
*.tfplan
*.otplan
.ssh/
_terramate_generated_*

# Decrypted working copies — never commit plaintext secrets.
# The example template (unencrypted, no real values) IS committed.
secrets/*.env.plain
secrets/*.dec

# Local per-machine env (direnv); .envrc.example is committed as a template
.envrc
